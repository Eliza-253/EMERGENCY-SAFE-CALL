<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/login"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@drawable/emergency"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App Title -->

    <TextView
        android:text="SafeCall - Emergency Help"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#E53935"
        android:layout_marginBottom="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Safety message -->

    <TextView
        android:text="Login to access instant emergency help and safety alerts"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Email -->

    <EditText
        android:id="@+id/email"
        android:hint="Enter Email"
        android:inputType="textEmailAddress"
        android:drawableStart="@drawable/baseline_email_24"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Password -->

    <EditText
        android:id="@+id/password"
        android:hint="Enter Password"
        android:inputType="textPassword"
        android:drawableStart="@drawable/baseline_key_24"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Emergency Access Button -->

    <Button
        android:id="@+id/loginBtn"
        android:text="Access Emergency Services"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Signup -->

    <TextView
        android:id="@+id/signupText"
        android:text="New user? Create Safety Account"
        android:textColor="#FFCDD2"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>